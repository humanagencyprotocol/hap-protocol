---
import '../styles/global.css';
import { siteConfig } from '../config';
import QRCode from 'qrcode';

interface Props {
  title: string;
  description?: string;
}

const { title, description = siteConfig.description } = Astro.props;
const currentPath = Astro.url.pathname;
const version = siteConfig.version;

// Build-time QR code for the mobile share popup — an inline SVG of this page's
// canonical URL, so no client-side JS or QR library is needed to render it.
const pageUrl = new URL(currentPath, Astro.site ?? 'https://humanagencyprotocol.org').href;
const shareQrSvg = await QRCode.toString(pageUrl, {
  type: 'svg',
  margin: 0,
  color: { dark: '#111111', light: '#ffffff' },
});
// Drop the brand prefix for a clean label; hide the line if it equals the brand.
const shareTitle = title.replace(/^(HAP|Human Agency Protocol)\s*[-–—|:]\s*/i, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
</head>
<body>
    <nav>
        <div class="container">
            <div class="logo-group">
                <a href="/" class="logo">Human Agency Protocol</a>
                <span class="version-badge">v{version}</span>
            </div>
            <button class="nav-share" id="share-toggle" type="button" aria-label="Share this page">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="18" cy="5" r="3"></circle>
                    <circle cx="6" cy="12" r="3"></circle>
                    <circle cx="18" cy="19" r="3"></circle>
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                </svg>
            </button>
            <button class="burger" id="burger-menu" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul id="nav-menu">
                <li><a href="/protocol" class={currentPath.startsWith('/protocol') ? 'active' : ''}>Protocol</a></li>
                <li><a href="/governance" class={currentPath.startsWith('/governance') ? 'active' : ''}>Governance</a></li>
                <li><a href="/review" class={currentPath.startsWith('/review') ? 'active' : ''}>Review</a></li>
                <li><a href="https://github.com/humanagencyprotocol/hap-protocol" target="_blank" rel="noopener noreferrer">GitHub</a></li>
            </ul>
        </div>
    </nav>

    <div class="share-overlay" id="share-overlay" role="dialog" aria-modal="true" aria-label="Share this page">
        <div class="share-modal">
            <button class="share-close" id="share-close" type="button" aria-label="Close">×</button>
            <div class="share-brand">humanagencyprotocol.org</div>
            {shareTitle && shareTitle !== siteConfig.title && <div class="share-title">{shareTitle}</div>}
            <div class="share-qr" set:html={shareQrSvg}></div>
            <div class="share-url">{pageUrl}</div>
        </div>
    </div>

    <slot />

    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Protocol</h4>
                <ul>
                    <li><a href="/protocol">Overview</a></li>
                    <li><a href="/protocol#profiles">Profiles</a></li>
                    <li><a href="/protocol#commitment-modes">Commitment Modes</a></li>
                    <li><a href="/protocol#execution-receipts">Execution Receipts</a></li>
                    <li><a href="/protocol#authority-server-behavior">Authority Server</a></li>
                    <li><a href="/protocol#gatekeeper--executor-behavior">Gatekeeper</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Community</h4>
                <ul>
                    <li><a href="/governance">Governance</a></li>
                    <li><a href="/review">Review</a></li>
                    <li><a href="https://www.humanagencyprotocol.com/" target="_blank" rel="noopener noreferrer">Get Started</a></li>
                    <li><a href="https://github.com/humanagencyprotocol/hap-protocol">GitHub</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p><a href="/impress">Impress</a> | The Human Agency Protocol is open infrastructure. Licensed under MIT. Maintained by stewards, not owners.</p>
        </div>
    </footer>
</body>
</html>

<style>
    footer {
        max-width: 1200px;
        margin: 8rem auto 0;
        padding: 4rem 2rem;
        border-top: 1px solid var(--border);
    }

    .footer-content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 3rem;
    }

    .footer-section h4 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .footer-section ul {
        list-style: none;
        margin: 0;
    }

    .footer-section ul li {
        margin-bottom: 0.75rem;
    }

    .footer-section a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .footer-section a:hover {
        color: var(--accent);
    }

    .footer-bottom {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
        color: var(--text-tertiary);
        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        footer {
            margin-top: 4rem;
        }
    }
</style>

<script>
    // Burger menu toggle
    const burger = document.getElementById('burger-menu');
    const navMenu = document.getElementById('nav-menu');

    burger?.addEventListener('click', () => {
        burger.classList.toggle('active');
        navMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
        if (!burger?.contains(e.target as Node) && !navMenu?.contains(e.target as Node)) {
            burger?.classList.remove('active');
            navMenu?.classList.remove('active');
        }
    });

    // Close menu when clicking a link
    navMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            burger?.classList.remove('active');
            navMenu?.classList.remove('active');
        });
    });

    // Share popup (mobile QR)
    const shareToggle = document.getElementById('share-toggle');
    const shareOverlay = document.getElementById('share-overlay');
    const shareClose = document.getElementById('share-close');
    const closeShare = () => shareOverlay?.classList.remove('open');
    shareToggle?.addEventListener('click', () => shareOverlay?.classList.add('open'));
    shareClose?.addEventListener('click', closeShare);
    shareOverlay?.addEventListener('click', (e) => {
        if (e.target === shareOverlay) closeShare();
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeShare();
    });
</script>
