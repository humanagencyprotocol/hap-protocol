---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  version?: string;
  date?: string;
  nextPage?: { url: string; label: string };
  breadcrumb?: { url: string; label: string }[];
}

const { title, version, date, nextPage, breadcrumb } = Astro.props;
---

<BaseLayout title={`HAP - ${title}`}>
    {breadcrumb && breadcrumb.length > 0 && (
        <nav class="breadcrumb-bar" aria-label="Breadcrumb">
            <div class="breadcrumb-inner">
                {breadcrumb.map((item, i) => (
                    <>
                        <a href={item.url}>{item.label}</a>
                        {i < breadcrumb.length - 1 && <span class="breadcrumb-sep">/</span>}
                    </>
                ))}
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">{title}</span>
            </div>
        </nav>
    )}
    <article class:list={['content', { 'has-breadcrumb': breadcrumb && breadcrumb.length > 0 }]}>
        {(version || date) && (
            <div class="version-badge-top">
                {version && <a href="/changelog" class="version-pill">{version}</a>}
                {date && <span class="version-date">{date}</span>}
            </div>
        )}
        <h1>{title}</h1>
        <slot />
        {nextPage && (
            <div class="next-page">
                <a href={nextPage.url} class="btn btn-primary">
                    Next: {nextPage.label} →
                </a>
            </div>
        )}
    </article>
</BaseLayout>

<style>
    .version-badge-top {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
    }

    a.version-pill {
        display: inline-block;
        color: var(--text-tertiary);
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        padding: 0.35rem 0.85rem;
        border-radius: 2rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

    a.version-pill:hover {
        color: var(--accent);
        border-color: var(--accent);
        text-decoration: none;
    }

    .version-date {
        color: var(--text-tertiary);
        font-weight: 400;
    }

    .breadcrumb-bar {
        position: fixed;
        top: var(--nav-height);
        left: 0;
        width: 100%;
        background: var(--bg-main);
        border-bottom: 1px solid var(--border);
        z-index: 999;
    }

    .breadcrumb-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.5rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        line-height: 1;
    }

    .breadcrumb-bar a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb-bar a:hover {
        color: var(--accent);
    }

    .breadcrumb-sep {
        color: var(--text-tertiary);
    }

    .breadcrumb-current {
        color: var(--text-secondary);
    }

    .has-breadcrumb {
        padding-top: 14.5rem;
    }

    @media (max-width: 768px) {
        .has-breadcrumb {
            padding-top: 8.5rem;
        }
    }
</style>
