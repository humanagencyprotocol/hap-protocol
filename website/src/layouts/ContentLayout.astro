---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  version?: string;
  date?: string;
  nextPage?: { url: string; label: string };
  breadcrumb?: { url: string; label: string }[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, version, date, nextPage, breadcrumb, headings = [] } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={`HAP - ${title}`}>
    {breadcrumb && breadcrumb.length > 0 && (
        <nav class="breadcrumb-bar" aria-label="Breadcrumb">
            <div class="breadcrumb-inner">
                {breadcrumb.map((item, i) => (
                    <>
                        <a href={item.url}>{item.label}</a>
                        {i < breadcrumb.length - 1 && <span class="breadcrumb-sep">/</span>}
                    </>
                ))}
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">{title}</span>
            </div>
        </nav>
    )}
    <div class:list={['doc-layout', { 'has-toc': toc.length > 0 }]}>
        {toc.length > 0 && (
            <aside class="toc">
                <details class="toc-box" open>
                    <summary>On this page</summary>
                    <nav class="toc-nav" aria-label="On this page">
                        {toc.map((h) => (
                            <a href={`#${h.slug}`} class:list={['toc-link', `toc-d${h.depth}`]}>{h.text}</a>
                        ))}
                    </nav>
                </details>
            </aside>
        )}
        <article class:list={['content', { 'has-breadcrumb': breadcrumb && breadcrumb.length > 0 }]}>
            {(version || date) && (
                <div class="version-badge-top">
                    {version && <span class="version-pill">{version}</span>}
                    {date && <span class="version-date">{date}</span>}
                </div>
            )}
            <h1>{title}</h1>
            <slot />
            {nextPage && (
                <div class="next-page">
                    <a href={nextPage.url} class="btn btn-primary">
                        Next: {nextPage.label} →
                    </a>
                </div>
            )}
        </article>
    </div>
</BaseLayout>

<script>
    // Scroll-spy: highlight the current section in the TOC (the site's one JS exception).
    const links = Array.from(document.querySelectorAll('.toc-link')) as HTMLAnchorElement[];
    if (links.length) {
        const byId = new Map(links.map((l) => [decodeURIComponent(l.hash.slice(1)), l]));
        const setActive = (id: string) =>
            links.forEach((l) => l.classList.toggle('active', byId.get(id) === l));
        const heads = Array.from(document.querySelectorAll('.content h2[id], .content h3[id]'));
        const obs = new IntersectionObserver(
            (entries) => {
                const visible = entries
                    .filter((e) => e.isIntersecting)
                    .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
                if (visible[0]) setActive((visible[0].target as HTMLElement).id);
            },
            { rootMargin: '-100px 0px -65% 0px', threshold: 0 }
        );
        heads.forEach((h) => obs.observe(h));

        // Collapse the TOC by default on small screens (it ships open for desktop).
        const box = document.querySelector('.toc-box');
        if (box && !window.matchMedia('(min-width: 901px)').matches) box.removeAttribute('open');
    }
</script>

<style>
    /* ── Doc layout: sticky TOC sidebar + content ──────────────────── */
    .doc-layout {
        max-width: 1200px;  /* match the nav .container so the TOC lines up with the logo */
        margin: 0 auto;
        padding: 11rem 1.5rem 4rem;
        display: grid;
        gap: 3.5rem;
        grid-template-columns: minmax(0, 1fr);
    }
    .doc-layout.has-toc { grid-template-columns: 232px minmax(0, 1fr); }
    /* the grid owns width/padding; reset the global .content box */
    .doc-layout .content { max-width: 820px; margin: 0; padding: 0; }

    .toc { min-width: 0; }
    .toc-box > summary {
        cursor: pointer;
        list-style: none;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-tertiary);
        padding: 0.6rem 0;
    }
    .toc-box > summary::-webkit-details-marker { display: none; }
    .toc-nav {
        display: flex;
        flex-direction: column;
        border-left: 1px solid var(--border);
        /* reset the global bare-`nav` rule (position:fixed; width:100%; translucent bg; blur; z-index) */
        position: static;
        top: auto;
        width: auto;
        background: none;
        backdrop-filter: none;
        border-bottom: none;
        z-index: auto;
    }
    .toc-link {
        padding: 0.32rem 0 0.32rem 1rem;
        margin-left: -1px;
        border-left: 2px solid transparent;
        font-size: 0.85rem;
        line-height: 1.35;
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc-link.toc-d3 { padding-left: 2rem; font-size: 0.8rem; }
    .toc-link:hover { color: var(--text-primary); text-decoration: none; }
    .toc-link.active { color: var(--accent); border-left-color: var(--accent); font-weight: 600; }

    @media (min-width: 901px) {
        .toc {
            position: sticky;
            top: calc(var(--nav-height) + 1.5rem);
            align-self: start;
            max-height: calc(100vh - var(--nav-height) - 3rem);
            overflow-y: auto;
        }
        .toc-box > summary { display: none; }  /* always open on desktop */
    }
    @media (max-width: 900px) {
        /* single column + hide the TOC on mobile */
        .doc-layout, .doc-layout.has-toc { grid-template-columns: minmax(0, 1fr); padding-top: 7rem; }
        .toc { display: none; }
        .doc-layout .content { max-width: 100%; }
    }

    .version-badge-top {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
    }

    .version-pill {
        display: inline-block;
        color: var(--text-tertiary);
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        padding: 0.35rem 0.85rem;
        border-radius: 2rem;
        font-weight: 500;
    }

    .version-date {
        color: var(--text-tertiary);
        font-weight: 400;
    }

    .breadcrumb-bar {
        position: fixed;
        top: var(--nav-height);
        left: 0;
        width: 100%;
        background: var(--bg-main);
        border-bottom: 1px solid var(--border);
        z-index: 999;
    }

    .breadcrumb-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.5rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        line-height: 1;
    }

    .breadcrumb-bar a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb-bar a:hover {
        color: var(--accent);
    }

    .breadcrumb-sep {
        color: var(--text-tertiary);
    }

    .breadcrumb-current {
        color: var(--text-secondary);
    }

    .has-breadcrumb {
        padding-top: 14.5rem;
    }

    @media (max-width: 768px) {
        .has-breadcrumb {
            padding-top: 8.5rem;
        }
    }
</style>
